generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id          String   @id @default(cuid())
  accountName String   @unique
  passwordHash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?
  player      Player?
}

model Player {
  id             String   @id @default(cuid())
  accountId      String   @unique
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  characterClass String
  level          Int      @default(1)
  exp            Int      @default(0)
  expToNext      Int      @default(100)
  gold           Int      @default(50)
  positionX      Int      @default(0)
  positionY      Int      @default(0)
  positionMap    String   @default("town")
  currentHp      Int
  currentMp      Int
  dungeonId      String?
  isDead         Boolean  @default(false)
  inventory      Json     @default("[]")
  equipment      Json     @default("{\"weapon\":null,\"armor\":null,\"accessory\":null}")
  buffs          Json     @default("[]")
  skillCooldowns Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MonsterTemplate {
  id         String             @id @default(cuid())
  key        String             @unique
  name       String
  lootTable  Json               @default("[]")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  levelStats MonsterLevelStat[]
}

model MonsterLevelStat {
  id                String          @id @default(cuid())
  monsterTemplateId String
  monsterTemplate   MonsterTemplate @relation(fields: [monsterTemplateId], references: [id], onDelete: Cascade)
  level             Int
  hp                Int
  atk               Int
  def               Int
  critRate          Float           @default(0)
  critDamage        Float           @default(1.5)
  keenRate          Float           @default(0)
  keenDamage        Float           @default(2)
  dodgeRate         Float           @default(0)
  accuracyRate      Float           @default(1)
  penetration       Float           @default(0)
  blockRate         Float           @default(0)
  blockValue        Float           @default(0)
  attackSpeed       Float           @default(1)
  extraStats        Json            @default("{}")
  exp               Int
  gold              Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([monsterTemplateId, level])
}
